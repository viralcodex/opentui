      "import": "./src/runtime-modules.ts"
    }
  },
  "dependencies": {
    "@opentui/core": "workspace:*",
    "jimp": "1.6.1",
    "three": "0.177.0"
  },
  "optionalDependencies": {
    "@dimforge/rapier2d-simd-compat": "^0.17.3",
    "bun-webgpu": "0.1.7",
    "planck": "^1.4.2"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^24.0.0",
    "@types/three": "0.177.0",
    "commander": "^13.1.0",
    "typescript": "^5"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
